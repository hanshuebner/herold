# Build artefacts
/bin/
/dist/
/herold
/herold-*
*.exe
*.test
*.prof
*.pprof
coverage.out
coverage.html

# Editor / OS scratch
*~
.#*
\#*#
.DS_Store
.vscode/
.idea/

# A user's global .gitignore commonly excludes the emacs/etags `TAGS` and
# `tags` files (see https://git-scm.com/docs/gitignore). That pattern also
# matches our Markdoc tag-component directory at
# web/packages/manual/src/components/tags/, silently dropping the files
# from `git add`. Whitelist that path so the components are always tracked.
!/web/packages/manual/src/components/tags/
!/web/packages/manual/src/components/tags/*

# Go fuzz corpus caches (seed corpora under testdata/fuzz/ are checked in;
# the auto-generated corpus cache is not)
/cache/fuzz/
/pkg/
/go/

# Local dev scratch
/.envrc
/.env
/.env.local
/data/
/tmp/
/plugins/**/plugins/

# Container bind mounts
/deploy/docker/data/

# Web workspace build artefacts. The internal/webspa/dist/{suite,admin,manual}/
# tree is ephemeral build output -- populated either by `make build-web`
# (real Vite/SSR output) or by `make prep-web` (placeholder fallback so the
# //go:embed directive resolves on a clean checkout that has not run pnpm
# yet). The placeholder source lives under internal/webspa/placeholder/
# and is tracked. dist/.gitkeep is tracked so the embed root exists in a
# fresh clone.
/web/apps/*/dist/
/web/apps/*/.svelte-kit/
/web/node_modules/
/web/**/node_modules/
/internal/webspa/dist/admin/
/internal/webspa/dist/suite/
/internal/webspa/dist/manual/
