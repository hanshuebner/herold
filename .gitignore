# Container bind mounts
/deploy/docker/data/

# Web workspace build artefacts. The committed placeholders in
# internal/webspa/dist/{suite,admin}/index.html satisfy the //go:embed
# directive for go build / go test; `make build-web` overwrites
# index.html and adds an assets/ tree which we DO NOT commit. Run
# `git checkout internal/webspa/dist/` to restore the placeholder
# before committing if a build pollutes the tree.
/web/apps/*/dist/
/web/apps/*/.svelte-kit/
/web/node_modules/
/web/**/node_modules/
/internal/webspa/dist/suite/assets/
/internal/webspa/dist/admin/assets/
