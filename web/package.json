{
  "name": "herold-web",
  "version": "0.0.0",
  "private": true,
  "description": "Herold web workspace: the suite (mail / calendar / contacts / chat) and admin SPAs that ship inside the herold binary.",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @herold/suite dev",
    "build": "pnpm -r --if-present build",
    "check": "pnpm -r --if-present check",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
