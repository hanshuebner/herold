    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@herold/clientlog": "workspace:*",
    "@herold/design-system": "workspace:*",
    "bits-ui": "^2.18.0",
    "qrcode-svg": "^1.1.0",
    "source-map": "^0.7.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
