{
  "name": "@herold/manual",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Herold in-app and standalone manual viewer. Bundles Markdoc .mdoc source into JSON and renders via Svelte 5 components.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "node scripts/validate.mjs",
    "bundle": "node scripts/bundle.mjs"
  },
  "dependencies": {
    "@herold/design-system": "workspace:*",
    "@markdoc/markdoc": "^0.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
