$ORIGIN postfix.test.
$TTL 60

@   IN SOA  ns1.postfix.test. hostmaster.postfix.test. (
            2026042601 ; serial
            3600       ; refresh
            900        ; retry
            604800     ; expire
            60 )       ; minimum TTL

@   IN NS   ns1.postfix.test.
ns1 IN A    10.77.0.2

mail    IN A    10.77.0.12
postfix IN A    10.77.0.12
@       IN A    10.77.0.12

@   IN MX   10 mail.postfix.test.

@   IN TXT  "v=spf1 ip4:10.77.0.0/24 ~all"
_dmarc  IN TXT  "v=DMARC1; p=none; rua=mailto:dmarc@postfix.test"
